# ─────────────────────────────────────────
# 同時通訳アプリ 環境変数設定
# このファイルを .env にコピーして値を設定してください
# ─────────────────────────────────────────

# Claude API キー (翻訳エンジン)
# https://console.anthropic.com でAPIキーを取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# アプリ認証 PIN (8桁数字を推奨)
# 例: APP_PIN=12345678
APP_PIN=

# ポート番号（デフォルト: 3000）
# PORT=3000
